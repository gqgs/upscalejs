{
  "name": "upscalejs",
  "version": "2.0.0",
  "files": [
    "dist/upscalejs.es.js",
    "dist/*.d.ts",
    "dist/js",
    "dist/models"
  ],
  "type": "module",
  "types": "./dist/worker.d.ts",
  "description": "Upscale images using super resolution AI models",
  "browser": "./dist/upscalejs.es.js",
  "module": "./dist/upscalejs.es.js",
  "main": "./dist/upscalejs.es.js",
  "exports": {
    ".": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/upscalejs.es.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "lib": "vue-tsc -p tsconfig.lib.json --noEmit && vite build -c vite.lib.config.ts && vue-tsc -p tsconfig.lib.json -d --emitDeclarationOnly --outDir dist",
    "preview": "vite preview --port 5050",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "test": "vitest --run --threads false"
  },
  "dependencies": {},
  "keywords": [
    "image",
    "upscale",
    "ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gqgs/upscalejs.git"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@types/node": "^18.0.0",
    "@vue/eslint-config-typescript": "^10.0.0",
    "@vue/tsconfig": "^0.1.3",
    "onnxruntime-web": "^1.24.3",
    "prettier": "^2.6.2",
    "typescript": "~4.6.3",
    "vite": "^6.2.1",
    "vue": "^3.2.31",
    "vue-tsc": "^0.34.10"
  }
}
